# Flask Configuration
SECRET_KEY=your-secret-key-here-change-in-production

# Database URLs
DATABASE_URL=sqlite:///app.db
MONGODB_URI=mongodb://localhost:27017/
MONGODB_DB_NAME=travel_buddy_chat

# API Keys
OPENAI_API_KEY=your-openai-api-key

# Google Maps API
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Twilio Configuration (for SMS notifications)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ==================== OAuth Configuration ====================

# Google OAuth 2.0
# Get credentials from: https://console.cloud.google.com/
# Redirect URI: http://localhost:5000/auth/oauth/callback/google
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret

# Facebook OAuth
# Get credentials from: https://developers.facebook.com/apps/
# Redirect URI: http://localhost:5000/auth/oauth/callback/facebook
FACEBOOK_OAUTH_CLIENT_ID=your-facebook-app-id
FACEBOOK_OAUTH_CLIENT_SECRET=your-facebook-app-secret

# Twitter OAuth 2.0
# Get credentials from: https://developer.twitter.com/en/portal/dashboard
# Redirect URI: http://localhost:5000/auth/oauth/callback/twitter
# Requires: Read permissions, user identification
TWITTER_OAUTH_CLIENT_ID=your-twitter-client-id
TWITTER_OAUTH_CLIENT_SECRET=your-twitter-client-secret

# Host and Port Configuration
HOST=0.0.0.0
PORT=5000

# ==================== OAuth Setup Instructions ====================
# 
# GOOGLE OAUTH:
# 1. Go to https://console.cloud.google.com/
# 2. Create a new project
# 3. Enable Google+ API
# 4. Create OAuth 2.0 credentials (Web application)
# 5. Add http://localhost:5000 and http://localhost:5000/auth/oauth/callback/google to authorized URLs
# 6. Copy Client ID and Client Secret
# 7. Set GOOGLE_OAUTH_CLIENT_ID and GOOGLE_OAUTH_CLIENT_SECRET
#
# FACEBOOK OAUTH:
# 1. Go to https://developers.facebook.com/
# 2. Create a new app
# 3. Select "Consumer" as app type
# 4. Add "Facebook Login" product
# 5. Configure OAuth Redirect URIs: http://localhost:5000/auth/oauth/callback/facebook
# 6. In Settings > Basic, copy App ID and App Secret
# 7. Set FACEBOOK_OAUTH_CLIENT_ID and FACEBOOK_OAUTH_CLIENT_SECRET
#
# TWITTER OAUTH 2.0:
# 1. Go to https://developer.twitter.com/en/portal/dashboard
# 2. Create a new standalone app
# 3. Go to App Settings > Authentication Settings
# 4. Enable OAuth 2.0
# 5. Set Redirect URIs: http://localhost:5000/auth/oauth/callback/twitter
# 6. Copy Client ID and Client Secret
# 7. Set TWITTER_OAUTH_CLIENT_ID and TWITTER_OAUTH_CLIENT_SECRET
#
# ALL OAuth providers require HTTPS in production!
# Update these URLs when deploying to production.
